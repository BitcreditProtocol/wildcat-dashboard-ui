{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!dev-dist",
      "!dev-dist/**",
      "!dist/mockServiceWorker.js",
      "!public",
      "!public/**",
      "!public/mockServiceWorker.js",
      "!src/generated",
      "!src/generated/**",
      "!src/components/ui",
      "!src/components/ui/**",
      "!opt/wildcat/openapi.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "attributePosition": "auto",
    "indentWidth": 2,
    "lineWidth": 140
  },
  "assist": {
    "enabled": false
  },
  "linter": {
    "enabled": false
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  }
}
