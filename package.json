    "react-hook-form": "^7.75.0",
    "react-intl": "^10.1.7",
    "react-router": "^7.15.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@eslint/js": "^10.0.1",
    "@eslint/plugin-kit": "^0.7.1",
    "@formatjs/cli": "^6.16.0",
    "@hey-api/openapi-ts": "^0.97.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/big.js": "^6.2.2",
    "@types/node": "^25.8.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
