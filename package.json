{
  "name": "wildcat-dashboard-ui",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "engines": {
    "node": ">=25 <26",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
